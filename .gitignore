# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# insta snapshot leftovers (pending/unreviewed snapshots — never commit these)
*.snap.new
*.pending-snap

# IMPORTANT: Cargo.lock MUST stay committed.
# gnr8 is a binary project, so the lockfile is required for reproducible builds and
# for `cargo clippy --locked` in CI (RUST-03 / D-16). Do NOT add a Cargo.lock ignore line.

# scratch / external test copies (not committed)
.tmp/
dist/

# Python bytecode cache (generated by running the pyextract sidecar / its tests)
__pycache__/
*.pyc

# Node sidecar dependencies — never committed.
# `tsextract` borrows the USER's own `typescript` (resolved from the target project, like goextract
# uses `go` and pyextract uses `python3`); gnr8 ships no typescript. `typescript` is a devDependency
# for gnr8's OWN test suite only — restored on demand via `npm ci` in tsextract/ (gitignored), with
# the snapshot/typecheck tests skipping gracefully if node/typescript is absent.
node_modules/

# GSD transient state / sensitive auth-capture inbox — never commit
.planning/HANDOFF.json
.planning/.pending-auth-captures.*

# Test-created lifecycle state for fixtures that are not checked-in examples.
/fixtures/goalservice/.gnr8/
